import java.util.*;
class Node{
    int data;
    Node next;
    Node(int data){
        this.data = data;
        this.next = null;
    }
}
class LL{
    Node head = null;
    Node temp = null;
    
    void creation(int n, Scanner sc){
       
        for(int i=0;i<n;i++){
            int val = sc.nextInt();
        
            Node newnode = new Node(val);
            if(head==null){
                head = newnode;
                temp = newnode;
            }
            else{
                temp.next = newnode;
                temp = newnode;
            }
        }
    }
    void display(){
        temp = head;
        while(temp!=null){
            System.out.print(temp.data+" ");
            temp = temp.next;
        }
    }
    void merge(Node head2){
        if(head==null){
            head = head2;
            return;
        }
        temp = head;
        while(temp.next!=null){
            temp= temp.next;
        }
        temp.next = head2;
       
        
    }
    void sort(){
        for(Node i=head;i!=null;i=i.next){
            for(Node j=head;j!=null;j=j.next){
                if(i.data<j.data){
                    int temp = i.data;
                    i.data = j.data;
                    j.data = temp;
                }
            }
        }
    }
}
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        LL list1 = new LL();
        LL list2 = new LL();
        list1.creation(n, sc);
        list2.creation(n, sc);
        list1.merge(list2.head);
        list1.sort();
        list1.display();
       
        
    }
}
